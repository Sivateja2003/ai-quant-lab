# Copy this file to .env and fill in your credentials
# Get these from https://developers.kite.trade/

KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# After running `python auth.py --generate-session <request_token>`,
# paste the access token below so you don't need to re-authenticate each run.
KITE_ACCESS_TOKEN=your_access_token_here

# MySQL database connection settings
# Instructor's shared cohort database (source for historical data and simulator)
MYSQL_URL=mysql://username:password@host:3306/database_name

# ---------------------------------------------------------------------------
# Kite Simulator  (set KITE_USE_SIMULATOR=true to use simulator instead of Zerodha)
# ---------------------------------------------------------------------------
KITE_USE_SIMULATOR=false

# WebSocket URL of the simulator server
# Use ws://localhost:8765 if running the simulator on your own machine
# Use ws://INSTRUCTOR_IP:8765 if connecting to the instructor's simulator
KITE_SIM_URL=ws://localhost:8765

# Simulator credentials — get these from your instructor or from config/api_keys.json
# after running: python run.py simulator  (credentials are printed on first run)
KITE_SIM_API_KEY=sim_your_api_key_here
KITE_SIM_ACCESS_TOKEN=sat_your_access_token_here

# ---------------------------------------------------------------------------
# CLIENT_DB_URL — YOUR OWN database where simulator ticks get stored.
# Each student fills in their own credentials here.
# The tick_data table is created automatically on first connect.
# Leave blank to store in the same MYSQL_URL database above.
# Format: mysql://username:password@host:3306/database_name
# Example: mysql://root:yourpassword@localhost:3306/trading
# ---------------------------------------------------------------------------
CLIENT_DB_URL=
